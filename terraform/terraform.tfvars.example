# Copy this file to terraform.tfvars and fill in values
# NEVER commit terraform.tfvars to version control

aws_region   = "us-east-1"
environment  = "dev"
project_name = "todo-app"

vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]

# Database
db_instance_class = "db.t3.micro"
db_name           = "tododb"
db_username       = "todouser"
db_password       = "CHANGE_ME_STRONG_PASSWORD"

# EC2
ec2_instance_type = "t3.micro"
ec2_key_pair_name = "my-key-pair"   # must already exist in AWS

# Deployment options — set one to true
deploy_ec2 = true
deploy_eks = false  # set true for Kubernetes deployment

# EKS (only used if deploy_eks = true)
eks_node_instance_type = "t3.medium"
eks_desired_nodes      = 2
eks_min_nodes          = 1
eks_max_nodes          = 4
